# ===========================================================================
# ZGX AI API Container — Medical Triage Voice Agent
# ===========================================================================
# Based on NVIDIA vLLM container
# Includes: vLLM + Llama-3.1-8B-UltraMedical, faster-whisper STT, Piper TTS
#
# Build:
#   cd ~/Desktop/consent-agent/docker
#   docker build -t consent-agent:latest -f Dockerfile.api .
#
# Run:
#   docker run --rm -d \
#     --name zgx-ai-api \
#     --gpus all \
#     --network host \
#     -v ~/Desktop/consent-agent/models:/models \
#     consent-agent:latest
# ===========================================================================

FROM nvcr.io/nvidia/vllm:26.01-py3

ENV PYTHONUNBUFFERED=1
ENV CUDA_VISIBLE_DEVICES=0

# ----- System dependencies -----
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    wget \
    curl \
    portaudio19-dev \
    libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

# ----- Python dependencies -----
RUN pip install --no-cache-dir \
    fastapi \
    "uvicorn[standard]" \
    python-multipart \
    requests \
    faster-whisper \
    numpy

# ----- Piper TTS (aarch64) -----
ARG PIPER_VERSION=2023.11.14-2
RUN mkdir -p /opt/piper && \
    wget -q "https://github.com/rhasspy/piper/releases/download/${PIPER_VERSION}/piper_linux_aarch64.tar.gz" \
    -O /tmp/piper.tar.gz && \
    tar xzf /tmp/piper.tar.gz -C /opt/piper --strip-components=1 && \
    rm /tmp/piper.tar.gz && \
    ln -s /opt/piper/piper /usr/local/bin/piper

# ----- Pre-download Whisper models at build time -----
# Download multiple whisper models so you can switch via env var
ARG WHISPER_MODEL=base
RUN python3 -c "from faster_whisper import WhisperModel; WhisperModel('base', device='cpu', compute_type='int8'); print('base downloaded')"
RUN python3 -c "from faster_whisper import WhisperModel; WhisperModel('small', device='cpu', compute_type='int8'); print('small downloaded')"

# ----- App code -----
WORKDIR /app
COPY zgx_ai_api.py /app/zgx_ai_api.py

# ----- Default env vars -----
ENV WHISPER_MODEL_SIZE=base
ENV VLLM_URL=http://localhost:8001/v1/chat/completions
ENV VLLM_MODEL=/models/Llama-3.1-8B-Instruct-AWQ-INT4
ENV PIPER_MODEL=/models/piper-tts/en_US-lessac-medium.onnx

EXPOSE 8090 8001

# ----- Health check -----
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:8090/health || exit 1

# Default: run both vLLM + API together
CMD ["bash", "-c", "\
    echo 'Starting vLLM on port 8001...' && \
    python3 -m vllm.entrypoints.openai.api_server \
        --model ${VLLM_MODEL} \
        --port 8001 \
        --dtype auto \
        --quantization awq_marlin \
        --max-model-len 4096 \
        --gpu-memory-utilization 0.70 &\
    echo 'Waiting for vLLM...' && \
    for i in $(seq 1 120); do \
        curl -sf http://localhost:8001/v1/models > /dev/null 2>&1 && break; \
        sleep 5; \
    done && \
    echo 'vLLM ready. Starting API server...' && \
    python3 /app/zgx_ai_api.py \
"]